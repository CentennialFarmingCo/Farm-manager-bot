# Copy to .env and fill in. Never commit the real .env.
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=replace-with-bot-token

# Optional overrides
# URL the /dashboard command links to. Defaults to the live Vercel deployment.
# DASHBOARD_URL=https://centennial-farm-dashboard-qvytatulr.vercel.app
# FARM_DB_FILE=farm_data.db
# On Render with a persistent disk mounted at /var/data, set:
# FARM_DB_FILE=/var/data/farm_data.db
# FARM_FIELDS_FILE=fields_map.json
