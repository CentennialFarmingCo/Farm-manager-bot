# Copy to .env and fill in. Never commit the real .env.
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=replace-with-bot-token

# Optional overrides
# URL the /dashboard command links to. Defaults to the public Vercel production
# alias https://centennial-farm-dashboard-five.vercel.app.
# DASHBOARD_URL=https://centennial-farm-dashboard-five.vercel.app
# FARM_DB_FILE=farm_data.db
# On Render with a persistent disk mounted at /var/data, set:
# FARM_DB_FILE=/var/data/farm_data.db
# FARM_FIELDS_FILE=fields_map.json
# Override the JSON URL /seasonal fetches. Defaults to
# <DASHBOARD_URL>/phenology-summary.json.
# SEASONAL_URL=https://centennial-farm-dashboard-five.vercel.app/phenology-summary.json
# SEASONAL_API_TIMEOUT=8

# Harvest snapshot export — syncs `public/harvest.json` to the dashboard repo
# after each harvest log so the Harvest tab updates on the next Vercel build.
# Without a PAT, harvest logs still save locally; only the dashboard sync is
# skipped. PAT must have Contents:Read+Write on the dashboard repo only.
# HARVEST_EXPORT_PAT=github_pat_xxx
# HARVEST_EXPORT_REPO=CentennialFarmingCo/centennial-farm-dashboard
# HARVEST_EXPORT_PATH=public/harvest.json
# HARVEST_EXPORT_BRANCH=main
# HARVEST_EXPORT_MIN_INTERVAL=30
